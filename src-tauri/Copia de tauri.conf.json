{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ferreteria",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "devUrl": "http://127.0.0.1:4200",
    "frontendDist": "../dist/ferreteria",
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Ferreteria",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
